# Aethery brain — copy to brain/.env on the NUC and fill in

# Shared secret; must match `wrangler secret put BRAIN_SECRET` on the Worker side
BRAIN_SECRET=

# Bind address / port (cloudflared connects to this locally)
BRAIN_HOST=127.0.0.1
BRAIN_PORT=3123

# Optional overrides
# CLAUDE_BIN=claude
# BRAIN_CLAUDE_MODEL=sonnet
# BRAIN_REPO_DIR=/path/to/xaolonist.eth
# BRAIN_MAX_CONCURRENT=2
# BRAIN_TURN_TIMEOUT_MS=150000
# BRAIN_RATE_LIMIT_PER_HOUR=20
