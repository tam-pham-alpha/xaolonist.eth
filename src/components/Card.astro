---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;
const postLink = data.lang === 'en' ? `/en/blog/${data.slug}` : `/blog/${data.slug}`;
---

<div class="max-w-[500px] mb-16 lg:mx-6 lg:w-[calc(33.33%-48px)] lg:mb-9">
  <div class="mb-4 h-[220px] rounded-lg overflow-hidden relative">
    <a href={postLink}>
      <div class="w-full absolute left-0 right-0 top-1/2 -translate-y-1/2">
        <Image
          src={data.cover}
          alt={data.title}
          width={800}
          quality={80}
          format="webp"
        />
      </div>
    </a>
  </div>
  <div>
    <h4 class="text-[18px] mb-3 lg:mt-3">
      <a href={postLink} class="text-white hover:text-white hover:no-underline">{data.title}</a>
    </h4>
    <p class="mt-3 mb-[0.5em] text-[#b3b3b3] lg:mb-3">{data.summary}</p>
    <div class="text-[12px]">
      {data.date ? <span class="text-[#868f97]">{new Date(data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span> : null}
      {data.cowriter ? <span class="text-[#868f97]"> • {data.cowriter}</span> : null}
    </div>
  </div>
</div>
