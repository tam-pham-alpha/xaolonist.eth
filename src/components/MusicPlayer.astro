---
interface Props {
  src: string;
  title: string;
  lyrics?: Array<{ text: string; start: number; end: number }>;
}

const { src, title, lyrics = [] } = Astro.props;
---

<div class="music-player-container bg-white/5 backdrop-blur-md border border-white/10 rounded-xl p-4 my-4 max-w-[760px] mx-auto select-none transition-all duration-300 hover:border-white/20">
  <!-- Top row: Play/Pause button, Track Info, Progress bar, Time, Loop -->
  <div class="flex items-center gap-4">
    <!-- Play button -->
    <button class="play-btn w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 hover:scale-105 active:scale-95 flex items-center justify-center text-white transition-all cursor-pointer shadow-lg border border-white/5" aria-label="Play">
      <!-- Play Icon -->
      <svg class="play-icon w-4 h-4 fill-current ml-0.5" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <!-- Pause Icon -->
      <svg class="pause-icon w-4 h-4 fill-current hidden" viewBox="0 0 24 24">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
      </svg>
    </button>

    <!-- Info & Progress -->
    <div class="flex-1 flex flex-col gap-1 min-w-0">
      <div class="flex justify-between items-baseline gap-2">
        <span class="text-sm font-medium text-white truncate flex items-center gap-1.5">
          <span class="text-xs text-[#ffc436] animate-pulse music-note-indicator">♪</span> {title}
        </span>
        <span class="text-xs text-white/40 font-mono time-display">0:00 / 0:00</span>
      </div>
      
      <!-- Progress Bar -->
      <div class="progress-bar-container h-1.5 bg-white/10 rounded-full cursor-pointer relative group">
        <div class="progress-bar h-full bg-[#ffc436] rounded-full w-0 transition-all duration-75 relative">
          <!-- Seek handle -->
          <div class="seek-handle w-3 h-3 bg-white rounded-full absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity shadow-md"></div>
        </div>
      </div>
    </div>

    <!-- Controls: Loop -->
    <button class="loop-btn p-2 text-white/40 hover:text-white transition-colors cursor-pointer rounded-lg hover:bg-white/5" title="Loop" aria-label="Loop">
      <svg class="w-5 h-5 fill-none stroke-current stroke-2" viewBox="0 0 24 24">
        <path d="M17 1l4 4-4 4M21 5H9a4 4 0 0 0-4 4v2M7 23l-4-4 4-4M3 19h12a4 4 0 0 0 4-4v-2"/>
      </svg>
    </button>
  </div>

  <!-- Bottom row: Attribution/Subtitle text -->
  <div class="flex justify-between items-center mt-3 text-xs text-white/40 border-t border-white/5 pt-2">
    <div>
      [Suno · <span class="text-[#ffc436]/80 font-medium">anh4gs</span>]
    </div>
    <div class="lyrics-cue truncate text-right max-w-[70%] min-h-[1.25rem] italic text-[#ffc436]/80 transition-all duration-300"></div>
  </div>

  <audio class="audio-element hidden" src={src} preload="metadata" data-lyrics={JSON.stringify(lyrics)}></audio>
</div>

<script>
  // Simple Vanilla JS initialization for each player on the page
  function setupPlayers() {
    const containers = document.querySelectorAll('.music-player-container');

    containers.forEach((container) => {
      const audio = container.querySelector('.audio-element') as HTMLAudioElement;
      const playBtn = container.querySelector('.play-btn') as HTMLButtonElement;
      const playIcon = container.querySelector('.play-icon') as SVGElement;
      const pauseIcon = container.querySelector('.pause-icon') as SVGElement;
      const progressBarContainer = container.querySelector('.progress-bar-container') as HTMLDivElement;
      const progressBar = container.querySelector('.progress-bar') as HTMLDivElement;
      const timeDisplay = container.querySelector('.time-display') as HTMLSpanElement;
      const loopBtn = container.querySelector('.loop-btn') as HTMLButtonElement;
      const lyricsCue = container.querySelector('.lyrics-cue') as HTMLDivElement;
      const musicNote = container.querySelector('.music-note-indicator') as HTMLSpanElement;

      if (!audio || !playBtn || !progressBarContainer || !progressBar || !timeDisplay || !loopBtn || !lyricsCue) return;

      let isLooping = false;
      let lyrics: Array<{ text: string; start: number; end: number }> = [];

      try {
        const rawLyrics = audio.getAttribute('data-lyrics');
        if (rawLyrics) {
          lyrics = JSON.parse(rawLyrics);
        }
      } catch (err) {
        console.error('Failed to parse lyrics data attribute', err);
      }

      function formatTime(secs: number) {
        if (isNaN(secs)) return '0:00';
        const minutes = Math.floor(secs / 60);
        const seconds = Math.floor(secs % 60);
        return `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
      }

      function updateTimeDisplay() {
        timeDisplay.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration || 0)}`;
      }

      // Play/Pause toggle
      playBtn.addEventListener('click', () => {
        if (audio.paused) {
          // Pause all other players on the page first
          document.querySelectorAll('.audio-element').forEach((el) => {
            const otherAudio = el as HTMLAudioElement;
            if (otherAudio !== audio && !otherAudio.paused) {
              otherAudio.pause();
              // trigger play state updates for other players
              const otherContainer = otherAudio.closest('.music-player-container');
              if (otherContainer) {
                const otherPlayIcon = otherContainer.querySelector('.play-icon') as SVGElement;
                const otherPauseIcon = otherContainer.querySelector('.pause-icon') as SVGElement;
                const otherNote = otherContainer.querySelector('.music-note-indicator') as HTMLSpanElement;
                otherPlayIcon?.classList.remove('hidden');
                otherPauseIcon?.classList.add('hidden');
                otherNote?.classList.remove('animate-pulse');
              }
            }
          });

          audio.play().catch((err) => console.error('Audio play failed:', err));
          playIcon.classList.add('hidden');
          pauseIcon.classList.remove('hidden');
          musicNote.classList.add('animate-pulse');
        } else {
          audio.pause();
          playIcon.classList.remove('hidden');
          pauseIcon.classList.add('hidden');
          musicNote.classList.remove('animate-pulse');
        }
      });

      // Update progress bar & time
      audio.addEventListener('timeupdate', () => {
        const duration = audio.duration || 0;
        const progress = duration > 0 ? (audio.currentTime / duration) * 100 : 0;
        progressBar.style.width = `${progress}%`;
        updateTimeDisplay();

        // Sync Subtitles
        const currentTime = audio.currentTime;
        const activeLine = lyrics.find(
          (line) => currentTime >= line.start && currentTime <= line.end
        );
        if (activeLine) {
          if (lyricsCue.textContent !== activeLine.text) {
            lyricsCue.style.opacity = '0';
            setTimeout(() => {
              lyricsCue.textContent = activeLine.text;
              lyricsCue.style.opacity = '1';
            }, 100);
          }
        } else {
          // Clear text when there's no active lyric line
          if (lyricsCue.textContent !== '') {
            lyricsCue.style.opacity = '0';
            setTimeout(() => {
              lyricsCue.textContent = '';
            }, 100);
          }
        }
      });

      audio.addEventListener('loadedmetadata', updateTimeDisplay);

      // Handle seek on progress bar click/drag
      function seek(e: MouseEvent) {
        const rect = progressBarContainer.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const width = rect.width;
        const duration = audio.duration || 0;
        if (duration > 0) {
          audio.currentTime = Math.min(Math.max((clickX / width) * duration, 0), duration);
        }
      }

      progressBarContainer.addEventListener('mousedown', (e) => {
        seek(e);
        function onMouseMove(moveEvent: MouseEvent) {
          seek(moveEvent);
        }
        function onMouseUp() {
          window.removeEventListener('mousemove', onMouseMove);
          window.removeEventListener('mouseup', onMouseUp);
        }
        window.addEventListener('mousemove', onMouseMove);
        window.addEventListener('mouseup', onMouseUp);
      });

      // Loop toggle
      loopBtn.addEventListener('click', () => {
        isLooping = !isLooping;
        audio.loop = isLooping;
        if (isLooping) {
          loopBtn.classList.remove('text-white/40');
          loopBtn.classList.add('text-[#ffc436]');
        } else {
          loopBtn.classList.remove('text-[#ffc436]');
          loopBtn.classList.add('text-white/40');
        }
      });

      // When track finishes (if not looping)
      audio.addEventListener('ended', () => {
        if (!isLooping) {
          playIcon.classList.remove('hidden');
          pauseIcon.classList.add('hidden');
          musicNote.classList.remove('animate-pulse');
          progressBar.style.width = '0%';
          lyricsCue.textContent = '';
        }
      });
    });
  }

  // Setup on initial page load
  setupPlayers();

  // Support Astro View Transitions (in case pages transition)
  document.addEventListener('astro:after-swap', setupPlayers);
</script>
