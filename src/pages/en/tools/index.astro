---
import Layout from '../../../layouts/Layout.astro';
import Container from '../../../components/Container.astro';
import { TOOLS } from '../../../lib/tools';

// Flat gallery for now — re-group by category when the list grows.
const tools = TOOLS;
const statusLabel: Record<string, string> = { live: '', beta: 'beta', soon: 'soon' };
---

<Layout
  title="tools — anh4gs"
  description="Small handy tools: batch image resizing and more"
  url="https://anh4gs.xyz/en/tools"
  lang="en"
>
  <div class="bg-darkmode min-h-screen pt-10 pb-20">
    <Container>
      <div class="max-w-[960px] mx-auto">
        <header class="mb-12">
          <h1 class="text-textColor text-[2rem] font-light tracking-[1px] m-0">
            🧰 tools
          </h1>
          <p class="text-[#888888] text-[0.95rem] mt-2 leading-relaxed max-w-[560px]">
            Small tools that get one thing done fast. No login, no fuss.
          </p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {tools.map((tool) => {
            const soon = tool.status === 'soon';
            const Tag = soon ? 'div' : 'a';
            return (
              <Tag
                href={soon ? undefined : `/en/tools/${tool.slug}`}
                class={`group block rounded-xl border border-white/10 bg-white/[0.03] p-5 transition-all ${
                  soon
                    ? 'opacity-50 cursor-default'
                    : 'hover:border-[#ffc436]/40 hover:bg-white/[0.06]'
                }`}
              >
                <div class="flex items-start gap-3">
                  <span class="text-[1.6rem] leading-none shrink-0">{tool.emoji}</span>
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      <h3 class="text-white text-[1rem] font-medium m-0">{tool.name.en}</h3>
                      {statusLabel[tool.status] && (
                        <span class="text-[0.65rem] uppercase tracking-wide text-[#ffc436]/80 border border-[#ffc436]/30 rounded px-1.5 py-0.5">
                          {statusLabel[tool.status]}
                        </span>
                      )}
                    </div>
                    <p class="text-[#888888] text-[0.85rem] mt-1 leading-relaxed">
                      {tool.description.en}
                    </p>
                  </div>
                </div>
              </Tag>
            );
          })}
        </div>
      </div>
    </Container>
  </div>
</Layout>
