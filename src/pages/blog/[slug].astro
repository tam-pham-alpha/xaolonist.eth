---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/Container.astro';
import MusicPlayer from '../../components/MusicPlayer.astro';
import MermaidLoader from '../../components/MermaidLoader.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    data.status === 'published' && data.lang === 'vn'
  );
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const siteUrl = 'https://anh4gs.xyz';
const postUrl = `${siteUrl}/blog/${data.slug}/`;

// Generate a JPEG version of the cover for social sharing (OG/Twitter)
// Social crawlers often don't support WebP
const ogImage = await getImage({ src: data.cover, width: 1200, format: 'jpg', quality: 80 });
const ogCover = `${siteUrl}${ogImage.src}`;

const formattedDate = new Date(data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Resolve local audio files using Vite glob import
const allAudio = import.meta.glob('/src/content/blog/**/*.mp3', { eager: true, import: 'default' });
const slugDir = post.data.slug;
let resolvedAudioUrl = '';

if (data.music) {
  const musicFilename = data.music.replace(/^\.\//, '');
  const key = `/src/content/blog/${slugDir}/${musicFilename}`;
  resolvedAudioUrl = allAudio[key] as string;
}

// Statically read and simplify lyrics JSON if it exists
let lyricsData = [];
if (data.music) {
  const lyricsFilename = data.lang === 'en' ? 'lyrics.en.json' : 'lyrics.json';
  const lyricsPath = path.join(process.cwd(), 'src/content/blog', slugDir, lyricsFilename);
  if (fs.existsSync(lyricsPath)) {
    try {
      const raw = JSON.parse(fs.readFileSync(lyricsPath, 'utf-8'));
      if (raw.aligned_lyrics) {
        lyricsData = raw.aligned_lyrics.map((line: any) => ({
          text: line.text,
          start: line.start_s,
          end: line.end_s
        }));
      }
    } catch (e) {
      console.error(`Error parsing lyrics for ${slugDir}:`, e);
    }
  }
}
---

<Layout
  title={data.title}
  description={data.summary}
  cover={ogCover}
  url={postUrl}
  type="article"
  publishedTime={data.date}
  author="anh4gs"
  blur={true}
  lang={data.lang}
>
  <div class="bg-darkmode">
    <Container>
      <div class="mt-8 mb-16 relative lg:mt-[80px] lg:mb-40">
        <div class="max-w-[760px] mx-auto mb-12">
          <h1 class="max-w-[760px] mx-auto text-2xl leading-tight mb-3 lg:text-[40px] font-bold">
            {data.title}
          </h1>
          <div class="text-[14px] text-[#868f97] max-w-[760px] mx-auto mb-6">
            {formattedDate}
            {data.cowriter ? ` • ${data.cowriter}` : null}
          </div>

          {resolvedAudioUrl && (
            <MusicPlayer
              src={resolvedAudioUrl}
              title={data.title}
              lyrics={lyricsData}
            />
          )}
        </div>

        {data.cover && (
          <div class="mb-12 text-center max-w-[960px] mx-auto">
            <Image
              src={data.cover}
              alt={data.title}
              width={960}
              quality={80}
              format="webp"
            />
          </div>
        )}

        <section class="text-[17px] text-[rgba(255,255,255,0.8)] leading-[1.5] max-w-[760px] mx-auto markdown-content">
          <Content />
        </section>
        <MermaidLoader />
      </div>
    </Container>
  </div>
</Layout>
