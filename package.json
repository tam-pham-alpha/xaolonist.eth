    "@types/react-dom": "^18.0.11",
    "@types/react-helmet": "^6.1.6",
    "autoprefixer": "^10.5.0",
    "gatsby-plugin-postcss": "^6.16.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.0.4",
    "wrangler": "^4.95.0"
