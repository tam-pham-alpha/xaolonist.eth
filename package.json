{
  "name": "gatsby-starter-minimal-ts",
  "version": "1.0.0",
  "private": true,
  "description": "A Gatsby starter written in TypeScript with no plugins and a single welcome page.",
  "author": "Jude Agboola",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "dev": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "release": "yarn run build && yarn run deploy",
    "deploy": "yarn run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "preview": "yarn run build && wrangler dev"
  },
  "license": "0BSD",
  "dependencies": {
    "gatsby": "^5.9.0",
    "gatsby-image": "^3.11.0",
    "gatsby-plugin-google-tagmanager": "4.20.0",
